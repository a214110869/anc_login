   "fieldname": "status_hint",
   "fieldtype": "HTML",
   "options": "<div id='anc-status-banner' style='border-radius:8px;padding:11px 16px;font-size:13px;margin-top:6px;'></div><script>frappe.ready(function(){var el=document.getElementById('anc-status-banner');var enabled=cur_frm&&cur_frm.doc&&cur_frm.doc.enabled;if(enabled){el.style.cssText='background:#f0fdf4;border:1px solid #bbf7d0;color:#166534;border-radius:8px;padding:11px 16px;font-size:13px;';el.innerHTML='✅ صفحة الدخول المخصصة <strong>مفعّلة</strong> — الزوار يشاهدون تصميم ANC';}else{el.style.cssText='background:#fef9c3;border:1px solid #fde047;color:#854d0e;border-radius:8px;padding:11px 16px;font-size:13px;';el.innerHTML='⚠️ صفحة الدخول المخصصة <strong>معطّلة</strong> — النظام يستخدم صفحة ERPNext الافتراضية';}cur_frm.fields_dict.enabled.df.onchange=function(){frappe.ui.form.trigger('ANC Login Settings','enabled');};});</script>"
